# ─── Database ───────────────────────────────────────
# Local SQLite (default for development)
DATABASE_URL=sqlite:///./kamicode.db
# PostgreSQL via Supabase (uncomment for production)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ─── Clerk Auth ───────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Your Clerk JWKS URL for token verification (e.g., https://api.clerk.com/v1/jwks or https://<YOUR_DOMAIN>.clerk.accounts.dev/.well-known/jwks.json)
CLERK_JWKS_URL=
# Bypass authentication for local testing
BYPASS_AUTH=false

# ─── Convex Database ────────────────────────────────
CONVEX_URL=

# ─── AI Analysis ────────────────────────────────────
# OpenAI API key for code analysis (optional — app works without it)
OPENAI_API_KEY=

# ─── Code Runner ────────────────────────────────────
# "local" = subprocess execution (no API key needed, Python only)
# "piston" = Piston API (free sandbox runner API, supports multiple languages)
# "judge0" = Judge0 CE via RapidAPI (requires JUDGE0_API_KEY)
# "jdoodle" = JDoodle API (requires JDOODLE_CLIENT_ID and JDOODLE_CLIENT_SECRET)
CODE_RUNNER_MODE=local
CODE_RUNNER_TIMEOUT_SEC=5

# Piston config (only needed if CODE_RUNNER_MODE=piston)
PISTON_BASE_URL=https://emkc.org/api/v2/piston

# JDoodle config (only needed if CODE_RUNNER_MODE=jdoodle)
JDOODLE_CLIENT_ID=
JDOODLE_CLIENT_SECRET=

# Judge0 config (only needed if CODE_RUNNER_MODE=judge0)
JUDGE0_BASE_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# ─── Server ─────────────────────────────────────────
# Comma-separated CORS origins (use * for development)
CORS_ORIGINS=*
DEBUG=true
